# ─────────────────────────────────────────────
# CyberLab — Root Environment Example
# Copy to .env and fill in real values
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cyberlab
POSTGRES_USER=cyberlab
POSTGRES_PASSWORD=changeme_strong_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# JWT — MUST be >= 32 characters
JWT_ACCESS_SECRET=changeme_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CSRF — MUST be >= 32 characters
CSRF_SECRET=changeme_csrf_secret_min_32_chars_here

# Application
NODE_ENV=development
API_PORT=4001
WEB_PORT=4000
FRONTEND_URL=http://localhost:4000
API_URL=http://localhost:4001

# Email (SMTP) — use Mailtrap for development
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cyberlab.io

# Password hashing
PASSWORD_HASH_ROUNDS=12

# Rate limiting (requests per window)
THROTTLE_GLOBAL_LIMIT=100
THROTTLE_AUTH_LIMIT=5
THROTTLE_TTL_MS=60000

# Admin seed user (used by prisma/seed.ts)
SEED_ADMIN_EMAIL=admin@cyberlab.io
SEED_ADMIN_USERNAME=superadmin
SEED_ADMIN_PASSWORD=changeme_admin_password_strong

# ── Lab Sandbox ───────────────────────────────────────────────────────
# Provider for sandboxed labs (ssrf-demo, file-upload).
#   mock   → fake in-app URLs, no Docker needed (default in development)
#   docker → spawns real isolated containers (default in production)
# Requires the Docker socket mounted into the API container and the lab
# images pre-built via infra/sandbox-labs/build.sh
SANDBOX_PROVIDER=mock
SANDBOX_HOST=localhost
SANDBOX_SCHEME=http
SANDBOX_NETWORK=cyberlab_sandbox
DOCKER_SOCKET_PATH=/var/run/docker.sock
SANDBOX_TTL_MINUTES=60
SANDBOX_MEMORY_MB=256
SANDBOX_CPUS=0.5
SANDBOX_PORT_RANGE_START=21000
SANDBOX_PORT_RANGE_END=21999
