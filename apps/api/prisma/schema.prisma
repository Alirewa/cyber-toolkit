generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  USER
}

enum ToolRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMEOUT
}

enum ToolCategory {
  NETWORK
  ANALYSIS
  ENCODING
}

// â”€â”€ Phase 3: Bug Bounty Lab enums â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
enum LabDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LabCategory {
  XSS
  CSRF
  SQL_INJECTION
  IDOR
  AUTHENTICATION
  ACCESS_CONTROL
  JWT
  SSRF
  FILE_UPLOAD
  MISCONFIGURATION
  OWASP_TOP10
}

enum LabSessionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  RESET
}

enum SubmissionStatus {
  PENDING
  EVALUATING
  PASSED
  FAILED
}

enum AchievementType {
  FIRST_BLOOD
  COMPLETIONIST
  SPEED_RUN
  HINT_FREE
  STREAK
  CATEGORY_MASTER
  LEVEL_UP
  PERFECT_SCORE
  SCHOLAR
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  username        String    @unique
  passwordHash    String
  avatarUrl       String?
  bio             String?
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  isBanned        Boolean   @default(false)
  banReason       String?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  sessions       Session[]
  userRoles      UserRole[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  apiKeys        ApiKey[]
  settings       UserSettings?
  passwordResets PasswordReset[]
  toolRuns       ToolRun[]
  savedTargets   UserSavedTarget[]
  labSessions    LabSession[]
  labSubmissions LabSubmission[]
  labProgress    UserLabProgress[]
  hintUsages     HintUsage[]
  score          UserScore?
  achievements   UserAchievement[]

  // Phase 4 relations
  profileExtension UserProfileExtension?
  following      UserFollow[]       @relation("follower")
  followers      UserFollow[]       @relation("following")
  bookmarks      Bookmark[]
  activityTargets ActivityFeed[]    @relation("activityTarget")
  activityActions ActivityFeed[]    @relation("activityActor")
  reputationLogs ReputationLog[]
  teamMembers    TeamMember[]
  teamInvitesSent     TeamInvitation[] @relation("teamInviter")
  teamInvitesReceived TeamInvitation[] @relation("teamInvitee")
  teamActivityLogs    TeamActivityLog[]
  discussions    Discussion[]       @relation("discussionAuthor")
  discussionReplies DiscussionReply[] @relation("replyAuthor")
  discussionVotes   DiscussionVote[]
  writeups       Writeup[]          @relation("writeupAuthor")
  notes          Note[]
  mentorProfile  MentorProfile?
  mentorRequests    MentorshipRequest[] @relation("studentMentor")
  studentRequests   MentorshipRequest[] @relation("mentorStudent")
  reportsFiled      CommunityReport[]   @relation("reporter")
  reportsReviewed   CommunityReport[]   @relation("reviewer")

  // Phase 5 relations
  workflows           Workflow[]          @relation("workflowAuthor")
  workflowExecutions  WorkflowExecution[] @relation("workflowExecutor")
  scheduledJobs       ScheduledJob[]
  findings            Finding[]           @relation("findingAuthor")
  assignedFindings    Finding[]           @relation("findingAssignee")
  findingComments     FindingComment[]    @relation("findingCommentAuthor")
  secReports          Report[]            @relation("reportAuthor")
  reportTemplates     ReportTemplate[]    @relation("reportTemplateAuthor")
  alertRules          AlertRule[]         @relation("alertRuleAuthor")
  secAlerts           Alert[]             @relation("alertRecipient")

  // Phase 6 relations
  orgMemberships OrganizationMember[]
  apiUsageLogs   ApiUsage[]

  @@index([email])
  @@index([username])
  @@index([deletedAt])
  @@index([isActive, isBanned])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  lastUsedAt   DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model RoleEntity {
  id          String   @id @default(cuid())
  name        Role     @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role RoleEntity @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

model Permission {
  id          String  @id @default(cuid())
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       RoleEntity @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ApiKey {
  id             String      @id @default(cuid())
  userId         String
  organizationId String?
  name           String
  keyHash        String      @unique
  scope          ApiKeyScope @default(FULL_ACCESS)
  quotaPerDay    Int?
  usageToday     Int         @default(0)
  quotaResetAt   DateTime?
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  usageLogs    ApiUsage[]

  @@index([userId])
  @@index([keyHash])
  @@index([organizationId])
  @@map("api_keys")
}

model UserSettings {
  userId            String  @id
  theme             String  @default("dark")
  language          String  @default("en")
  notificationPrefs Json    @default("{}")
  privacySettings   Json    @default("{}")
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_resets")
}

model ToolDefinition {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String
  category    ToolCategory
  icon        String
  isEnabled   Boolean      @default(true)
  isNetwork   Boolean      @default(false)
  isInstant   Boolean      @default(false)
  inputSchema Json
  version     String       @default("1.0.0")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  runs        ToolRun[]

  @@index([slug])
  @@index([category])
  @@map("tool_definitions")
}

model ToolRun {
  id           String        @id @default(cuid())
  userId       String
  toolId       String
  input        Json
  status       ToolRunStatus @default(PENDING)
  result       Json?
  errorMessage String?
  executionMs  Int?
  queueJobId   String?
  retryCount   Int           @default(0)
  createdAt    DateTime      @default(now())
  completedAt  DateTime?
  updatedAt    DateTime      @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool         ToolDefinition @relation(fields: [toolId], references: [id])
  findings     Finding[]

  @@index([userId, createdAt])
  @@index([userId, toolId])
  @@index([status])
  @@index([queueJobId])
  @@map("tool_runs")
}

model UserSavedTarget {
  id        String   @id @default(cuid())
  userId    String
  label     String
  target    String
  notes     String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_saved_targets")
}

model FeatureFlag {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  isEnabled    Boolean  @default(false)
  rolloutPct   Int      @default(100)
  environments String[] @default(["production", "development"])
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("feature_flags")
}

model Module {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  version     String   @default("1.0.0")
  isEnabled   Boolean  @default(false)
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@map("modules")
}

// â”€â”€ Phase 3: Bug Bounty Lab models â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Lab {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  description  String
  objective    String
  category     LabCategory
  difficulty   LabDifficulty
  icon         String
  isEnabled    Boolean       @default(true)
  isLocked     Boolean       @default(false)
  xpReward     Int           @default(10)
  estimatedMin Int           @default(20)
  isSandboxed  Boolean       @default(false)
  sandboxImage String?
  metadata     Json?         // questions, steps, hints structure
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions     LabSession[]
  submissions  LabSubmission[]
  progress     UserLabProgress[]
  discussions  Discussion[]
  writeups     Writeup[]
  notes        Note[]

  @@index([category])
  @@index([difficulty])
  @@map("labs")
}

model LabSession {
  id           String          @id @default(cuid())
  userId       String
  labId        String
  status       LabSessionStatus @default(ACTIVE)
  sandboxUrl   String?
  sandboxId    String?
  expiresAt    DateTime?
  startedAt    DateTime        @default(now())
  completedAt  DateTime?
  resetCount   Int             @default(0)

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab          Lab             @relation(fields: [labId], references: [id])
  submissions  LabSubmission[]

  @@index([userId, labId])
  @@index([status])
  @@index([expiresAt])
  @@map("lab_sessions")
}

model LabSubmission {
  id          String           @id @default(cuid())
  userId      String
  labId       String
  sessionId   String
  status      SubmissionStatus @default(PENDING)
  answers     Json
  score       Int?
  maxScore    Int
  feedback    Json?
  hintsUsed   Int              @default(0)
  xpEarned    Int              @default(0)
  timeSpentMs Int?
  createdAt   DateTime         @default(now())
  completedAt DateTime?

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab         Lab              @relation(fields: [labId], references: [id])
  session     LabSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, labId])
  @@index([status])
  @@map("lab_submissions")
}

model UserLabProgress {
  userId      String
  labId       String
  isCompleted Boolean   @default(false)
  bestScore   Int       @default(0)
  attempts    Int       @default(0)
  hintsUsed   Int       @default(0)
  completedAt DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab         Lab       @relation(fields: [labId], references: [id])

  @@id([userId, labId])
  @@map("user_lab_progress")
}

model HintUsage {
  id        String   @id @default(cuid())
  userId    String
  labId     String
  hintKey   String
  sessionId String
  usedAt    DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, labId, hintKey])
  @@index([userId, labId])
  @@map("hint_usages")
}

model UserScore {
  userId    String   @id
  totalXp   Int      @default(0)
  level     Int      @default(1)
  labsDone  Int      @default(0)
  streak    Int      @default(0)
  lastLabAt DateTime?
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_scores")
}

model Achievement {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String
  icon        String
  type        AchievementType
  xpReward    Int             @default(0)
  isSecret    Boolean         @default(false)
  createdAt   DateTime        @default(now())

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId        String
  achievementId String
  earnedAt      DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model LearningPath {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  isEnabled   Boolean  @default(true)
  labSlugs    String[]
  createdAt   DateTime @default(now())

  @@map("learning_paths")
}

