# ─────────────────────────────────────────────
# CyberLab API — Environment Variables
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4001
FRONTEND_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://cyberlab:changeme_strong_password@localhost:5432/cyberlab?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# JWT (>= 32 chars each)
JWT_ACCESS_SECRET=changeme_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CSRF (>= 32 chars)
CSRF_SECRET=changeme_csrf_secret_min_32_chars_here

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cyberlab.io

# Rate limiting
THROTTLE_GLOBAL_LIMIT=100
THROTTLE_AUTH_LIMIT=5
THROTTLE_TTL_MS=60000

# Seed admin
SEED_ADMIN_EMAIL=admin@cyberlab.io
SEED_ADMIN_USERNAME=superadmin
SEED_ADMIN_PASSWORD=changeme_admin_password_strong
